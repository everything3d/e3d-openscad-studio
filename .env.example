# Postgres connection string.
# Local dev: any Postgres works, e.g. postgres://<user>@localhost:5432/e3d_openscad_studio
# On Vercel: provisioned automatically when you add Neon (or another Postgres) from the Marketplace.
POSTGRES_URL=

# Vercel AI Gateway key (https://vercel.com/~/ai-gateway/api-keys).
# Only needed for local dev — deployments on Vercel authenticate via OIDC automatically.
AI_GATEWAY_API_KEY=

# Optional: override the agent model (default: openai/gpt-5.6-terra).
# STUDIO_MODEL=openai/gpt-5.4-mini
